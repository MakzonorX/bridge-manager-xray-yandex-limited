BRIDGE_DOMAIN=bridge.example.com
API_TOKEN=change_me
API_PUBLIC=false
API_ALLOW_FROM=
DISABLE_IPV6=true

# user->bridge mode
USER_MODE=reality
USER_PORT=443
USER_HOST_FOR_URI=bridge.example.com
USER_FLOW=xtls-rprx-vision

# reality settings
# Keep legacy_x5 for strict backward compatibility, or use max_ru/mail_ru/vk_com/auto_ru for new nodes.
REALITY_PROFILE=legacy_x5
REALITY_SERVER_NAME=
REALITY_DEST=
REALITY_SHORT_ID=
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_FINGERPRINT=chrome
REALITY_SPIDER_X=/

# bridge->exit settings
EXIT_HOST=s1.bytestand.fun
EXIT_PORT=443
EXIT_PATH=/bridge-xh
EXIT_SERVER_NAME=s1.bytestand.fun
BRIDGE_UUID_FOR_EXIT=7d28c9a1-e5f3-4b90-8a2f-d3e4b7c9f8a0

# only for USER_MODE=xhttp
ACME_EMAIL=admin@example.com

# traffic limit / throttle settings
LIMITED_THROTTLE_RATE_BYTES_PER_SEC=102400
LIMITED_TC_ENABLED=true
LIMITED_TC_EGRESS_IFACE=
LIMITED_TC_MARK=100
LIMITED_TC_CLASS_ID=1:10
LIMIT_POLL_INTERVAL_SECONDS=15
